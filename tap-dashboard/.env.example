# Stripe Environment Variables
# Add these to your .env.local file

# ============================================================================
# Stripe API Keys
# ============================================================================
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Webhook Secret
# Get this from `stripe listen --forward-to localhost:3000/api/stripe/webhook`
# Or from the Stripe Dashboard webhook settings
STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================================================
# Subscription Price IDs
# ============================================================================
# Create these in your Stripe Dashboard (Products & Pricing section)
# Then copy the price IDs here (format: price_xxxxxxxxxxxxxxxx)
STRIPE_PRICE_BUILDER=price_builder_placeholder
STRIPE_PRICE_PRO=price_pro_placeholder
STRIPE_PRICE_ENTERPRISE=price_enterprise_placeholder

# ============================================================================
# App Configuration
# ============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================================
# Optional: Stripe Settings
# ============================================================================

# Enable automatic tax calculation (requires Stripe Tax setup)
STRIPE_AUTOMATIC_TAX=false

# Optional: Stripe Connect Settings (for marketplace features)
STRIPE_CONNECT_CLIENT_ID=ca_...

# Optional: Platform Fee Configuration (default: 15%)
PLATFORM_FEE_PERCENT=15
MINIMUM_PLATFORM_FEE_CENTS=50

# Optional: Currency Settings (default: USD)
DEFAULT_CURRENCY=usd
