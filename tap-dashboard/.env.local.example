# ============================================================================
# MoltOS Environment Configuration
# ============================================================================
# Copy this file to .env.local and fill in your actual values

# ============================================================================
# Stripe API Keys (Required)
# ============================================================================
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Webhook Secret (Required for webhooks)
# Get this from `stripe listen --forward-to localhost:3000/api/stripe/webhook`
# Or from the Stripe Dashboard webhook settings
STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================================================
# Subscription Price IDs (Required)
# ============================================================================
# Create these in your Stripe Dashboard (Products & Pricing section)
# Then copy the price IDs here (format: price_xxxxxxxxxxxxxxxx)
STRIPE_PRICE_BUILDER=price_builder_placeholder
STRIPE_PRICE_PRO=price_pro_placeholder
STRIPE_PRICE_ENTERPRISE=price_enterprise_placeholder

# ============================================================================
# App Configuration (Required)
# ============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=${STRIPE_PUBLISHABLE_KEY}

# ============================================================================
# Database (Required for production)
# ============================================================================
# Database URL for subscription and user data
DATABASE_URL=postgresql://user:password@localhost:5432/moltos

# ============================================================================
# Authentication (Required)
# ============================================================================
# JWT secret for session signing
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Cookie name for auth session
AUTH_COOKIE_NAME=moltos_session

# ============================================================================
# Optional: Stripe Settings
# ============================================================================

# Enable automatic tax calculation (requires Stripe Tax setup)
STRIPE_AUTOMATIC_TAX=false

# Optional: Stripe Connect Settings (for marketplace features)
STRIPE_CONNECT_CLIENT_ID=ca_...

# Optional: Platform Fee Configuration (default: 15%)
PLATFORM_FEE_PERCENT=15
MINIMUM_PLATFORM_FEE_CENTS=50

# Optional: Currency Settings (default: USD)
DEFAULT_CURRENCY=usd

# ============================================================================
# Optional: Feature Flags
# ============================================================================
# Enable/disable specific features
ENABLE_TRADING_AGENT=true
ENABLE_SUPPORT_AGENT=true
ENABLE_CUSTOM_PRIMITIVES=true

# ============================================================================
# Optional: Monitoring & Analytics
# ============================================================================
# Sentry DSN for error tracking
SENTRY_DSN=

# Analytics API key
ANALYTICS_API_KEY=

# ============================================================================
# Optional: Email Configuration
# ============================================================================
# SMTP settings for sending transactional emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@moltos.io

# ============================================================================
# Test Configuration (Only for testing environments)
# ============================================================================
# Use mock Stripe for testing
STRIPE_MOCK_MODE=false

# Test webhook secret for local testing
STRIPE_WEBHOOK_SECRET_TEST=whsec_test_...

# ============================================================================
# Development Settings
# ============================================================================
# Enable debug logging
DEBUG=false

# Log level (error, warn, info, debug)
LOG_LEVEL=info
