{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://trust-audit-framework.io/schemas/trust-ledger-v1.0.json",
  "title": "TAP Trust Ledger",
  "description": "Schema for Trust Audit Protocol trust ledger claims",
  "type": "object",
  "required": [
    "agent_id",
    "claims",
    "signature"
  ],
  "properties": {
    "agent_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for the agent"
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "claim_id",
          "statement",
          "metric",
          "threshold",
          "operator",
          "confidence",
          "stake_amount",
          "stake_currency",
          "timestamp"
        ],
        "properties": {
          "claim_id": {
            "type": "string",
            "format": "uuid"
          },
          "statement": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500,
            "description": "Human-readable claim statement"
          },
          "metric": {
            "type": "string",
            "enum": [
              "response_time_ms",
              "uptime_percent",
              "availability",
              "accuracy_percent",
              "custom"
            ],
            "description": "The metric being claimed"
          },
          "threshold": {
            "type": "number",
            "description": "The threshold value for the metric"
          },
          "operator": {
            "type": "string",
            "enum": ["LESS_THAN", "GREATER_THAN", "EQUAL_TO", "NOT_EQUAL_TO"],
            "description": "Comparison operator for threshold"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Confidence level (0.0 to 1.0)"
          },
          "stake_amount": {
            "type": "number",
            "minimum": 500,
            "description": "Amount staked on this claim (minimum 500 ALPHA)"
          },
          "stake_currency": {
            "type": "string",
            "enum": ["ALPHA"],
            "description": "Currency of the stake"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "metadata": {
            "type": "object",
            "description": "Optional metadata about the claim"
          }
        }
      }
    },
    "signature": {
      "type": "string",
      "pattern": "^ed25519:[A-Za-z0-9+/=]+$",
      "description": "Ed25519 signature of the ledger"
    }
  },
  "additionalProperties": false
}
