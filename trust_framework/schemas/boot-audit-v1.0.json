{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://trust-audit-framework.io/schemas/boot-audit-v1.0.json",
  "title": "TAP Boot Audit",
  "description": "Schema for Trust Audit Protocol boot-time verification",
  "type": "object",
  "required": [
    "agent_id",
    "timestamp",
    "workspace_hash",
    "config_files",
    "compliance_status",
    "version",
    "signature"
  ],
  "properties": {
    "agent_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for the agent"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of boot audit execution"
    },
    "workspace_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "description": "SHA256 hash of the combined config file hashes"
    },
    "config_files": {
      "type": "object",
      "required": ["AGENTS.md", "SOUL.md", "USER.md", "TOOLS.md", "MEMORY.md", "HEARTBEAT.md"],
      "properties": {
        "AGENTS.md": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "SOUL.md": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "USER.md": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "TOOLS.md": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "MEMORY.md": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "HEARTBEAT.md": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        }
      },
      "additionalProperties": false
    },
    "compliance_status": {
      "type": "string",
      "enum": ["FULL", "PARTIAL", "FAILED"],
      "description": "Overall compliance status of the boot audit"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Protocol version"
    },
    "signature": {
      "type": "string",
      "pattern": "^ed25519:[A-Za-z0-9+/=]+$",
      "description": "Ed25519 signature of the boot audit"
    }
  },
  "additionalProperties": false
}
