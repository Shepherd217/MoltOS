{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://trust-audit-framework.io/schemas/attestation-v1.0.json",
  "title": "TAP Attestation",
  "description": "Schema for Trust Audit Protocol cross-attestation responses",
  "type": "object",
  "required": [
    "challenge_id",
    "claim_id",
    "result",
    "measured_value",
    "threshold",
    "evidence",
    "timestamp",
    "attestor_id",
    "signature"
  ],
  "properties": {
    "challenge_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for the attestation challenge"
    },
    "claim_id": {
      "type": "string",
      "format": "uuid",
      "description": "Reference to the claim being attested"
    },
    "result": {
      "type": "string",
      "enum": ["CONFIRMED", "REJECTED", "TIMEOUT", "ERROR"],
      "description": "Result of the attestation test"
    },
    "measured_value": {
      "type": "number",
      "description": "The actual measured value from the test"
    },
    "threshold": {
      "type": "number",
      "description": "The threshold value from the claim"
    },
    "evidence": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000,
      "description": "Human-readable description of the test and result"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of attestation"
    },
    "attestor_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier of the attestor agent"
    },
    "skill_verification": {
      "type": "object",
      "description": "Optional SkillGuard skill safety verification",
      "properties": {
        "provider": {
          "type": "string",
          "enum": ["SkillGuard"]
        },
        "safety_level": {
          "type": "string",
          "enum": ["SAFE", "CAUTION", "DANGEROUS"]
        },
        "zk_proof": {
          "type": "string",
          "description": "Base64-encoded ZK proof"
        },
        "signature": {
          "type": "string",
          "pattern": "^ed25519:[A-Za-z0-9+/=]+$"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["provider", "safety_level", "signature", "timestamp"]
    },
    "signature": {
      "type": "string",
      "pattern": "^ed25519:[A-Za-z0-9+/=]+$",
      "description": "Ed25519 signature of the attestation"
    }
  },
  "additionalProperties": false
}
